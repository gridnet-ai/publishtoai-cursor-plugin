{
  "name": "bigsearch-cursor-plugin",
  "private": true,
  "description": "BigSearch AI CLI, MCP server, and Cursor plugin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gridnet-ai/bigsearch-cursor-plugin.git"
  },
